# =============================================================================
# SECTION 10: EXPLICITLY ALLOWED FILES (DO NOT IGNORE)
# =============================================================================

# Environment templates (safe to commit)
!.env.example
!.env.template
!.env.sample
!.env.defaults

# GitHub Actions (safe)
!.github/

# Documentation (safe)
!README.md
!CONTRIBUTING.md
!LICENSE
!CHANGELOG.md
!ARCHITECTURE.md

# Config files (safe)
!.gitignore
!.dockerignore
!.editorconfig
!.prettierrc
!.eslintrc*
!.pre-commit-config.yaml

# Keep directories with .gitkeep
!.gitkeep

